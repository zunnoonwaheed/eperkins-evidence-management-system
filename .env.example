# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api

# Public URL (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public anon key (safe to expose in browser with RLS enabled)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (SECRET - never expose to browser, server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Application Configuration
# Base URL for certificate URLs (used in API responses)
# For local development:
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# For production:
NEXT_PUBLIC_APP_URL=https://eperkinslaw.com

# Certificate API Keys (SECRET - server-side only)
# Each automation app has its own API key
# Generate strong random keys for production (e.g., using: openssl rand -hex 32)
CERT_API_KEY_MYRPMCARE=your-secret-key-for-myrpmcare
CERT_API_KEY_CACOPHINEY=your-secret-key-for-cacophiney
CERT_API_KEY_THEGOODNEWS360=your-secret-key-for-thegoodnews360
CERT_API_KEY_FOURTH_SITE=your-secret-key-for-fourth-site

# Automation App Integration Configuration
# Used by external automation apps to call the certificate API

# Certificate API URL (where automation apps send requests)
# For local development:
# CERTIFICATE_API_URL=http://localhost:3000
# For production:
CERTIFICATE_API_URL=https://eperkinslaw.com

# Automation App API Keys (used by automation apps)
# These should match the CERT_API_KEY_* values above
MYRPMCARE_CERT_API_KEY=your-secret-key-for-myrpmcare
CACOPHINEY_CERT_API_KEY=your-secret-key-for-cacophiney
THEGOODNEWS360_CERT_API_KEY=your-secret-key-for-thegoodnews360
FOURTHSITE_CERT_API_KEY=your-secret-key-for-fourth-site

# CORS Configuration
# Comma-separated list of allowed origins
# For local development:
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:5001,http://localhost:5002,http://localhost:5003
# For production:
ALLOWED_ORIGINS=https://eperkinslaw.com,https://api.eperkinslaw.com,https://thegoodnews360.com,https://api.thegoodnews360.com,https://cacophiney.com,https://api.cacophiney.com
