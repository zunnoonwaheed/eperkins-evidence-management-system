# Flask Configuration
FLASK_SECRET_KEY=your-secret-key-here

# App Configuration
PORT=5002
APP_URL=http://localhost:5002
FRONTEND_URL=http://localhost:3002
HEADLESS=true

# Google Cloud Storage
GCS_BUCKET_NAME=your-bucket-name
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Eperkins Certificate Integration
EPERKINS_CERTIFICATE_API_URL=http://localhost:3000/api/certificates/create
EPERKINS_CERTIFICATE_API_KEY=your-certificate-api-key-here
EPERKINS_COMPANY_KEY=cacophiney
EPERKINS_WEBSITE=cacophiney.com
EPERKINS_SOURCE_SYSTEM=cacophiney-video-automation

# Optional
CONSENT_VERSION=1.0
