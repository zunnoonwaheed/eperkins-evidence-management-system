# Flask Configuration
# Generate strong secret key using: openssl rand -hex 32
FLASK_SECRET_KEY=your-secret-key-here

# App Configuration
PORT=5002

# Cacophiney Backend URL (used for generating certificate video URLs)
# For production (this is where the Cacophiney automation API runs):
APP_URL=https://api.cacophiney.com

# Frontend URL (the live website to automate)
# For production:
FRONTEND_URL=https://cacophiney.com/#qualify

# Headless Browser Mode
HEADLESS=true

# Google Cloud Storage (optional - leave empty for local storage)
GCS_BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS=

# Central Certificate API Configuration
# For production:
EPERKINS_CERTIFICATE_API_URL=https://eperkinslaw.com/api/certificates/create

# Generate using: openssl rand -hex 32
EPERKINS_CERTIFICATE_API_KEY=your-certificate-api-key-here

# Company Configuration
EPERKINS_COMPANY_KEY=cacophiney
EPERKINS_WEBSITE=cacophiney.com
EPERKINS_SOURCE_SYSTEM=cacophiney-video-automation

# Optional
CONSENT_VERSION=1.0
