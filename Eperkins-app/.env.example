# Google Cloud Storage Configuration
GCS_BUCKET_NAME=your-gcs-bucket-name

# Eperkins Certificate API Configuration
# For local development:
EPERKINS_CERTIFICATE_API_URL=http://localhost:3000/api/certificates/create

# For production (replace with your deployed domain):
# EPERKINS_CERTIFICATE_API_URL=https://eperkinslaw.com/api/certificates/create

# Eperkins API Authentication
EPERKINS_CERTIFICATE_API_KEY=your-api-key-here

# Company Configuration
EPERKINS_COMPANY_KEY=myrpmcare
EPERKINS_WEBSITE=myrpmcare.com
EPERKINS_SOURCE_SYSTEM=rpm-video-automation

# Flask Configuration
FLASK_SECRET_KEY=your-secret-key-here

# Flask App URL (used for generating certificate video URLs)
# For local development (using port 5001 because macOS uses 5000 for AirPlay):
APP_URL=http://localhost:5001
# For production:
# APP_URL=https://your-domain.com
