# Google Cloud Storage Configuration (optional - leave empty for local storage)
GCS_BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS=

# Eperkins Certificate API Configuration
# For local development:
# EPERKINS_CERTIFICATE_API_URL=http://localhost:3000/api/certificates/create
# For production:
EPERKINS_CERTIFICATE_API_URL=https://eperkinslaw.com/api/certificates/create

# Eperkins API Authentication
# This must match CERT_API_KEY_MYRPMCARE in the main Next.js .env file
# Generate using: openssl rand -hex 32
EPERKINS_CERTIFICATE_API_KEY=your-api-key-here

# Company Configuration
EPERKINS_COMPANY_KEY=myrpmcare
EPERKINS_WEBSITE=myrpmcare.com
EPERKINS_SOURCE_SYSTEM=rpm-video-automation

# Flask Configuration
# Generate strong secret key using: openssl rand -hex 32
FLASK_SECRET_KEY=your-secret-key-here

# Port Configuration
PORT=5003

# Flask App URL (used for generating certificate video URLs)
# For local development:
# APP_URL=http://localhost:5003
# For production (this is where the MyRPMCare automation API runs):
APP_URL=https://api.eperkinslaw.com

# Frontend URL (the live website to automate)
# For production:
FRONTEND_URL=http://www.myrpmcare.com/#eligibility

# Headless Browser Mode
HEADLESS=true
